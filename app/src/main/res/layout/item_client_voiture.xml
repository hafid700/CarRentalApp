<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="#1A1A1A"
    app:cardElevation="0dp">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- TOP ROW: icon + info + status badge -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <!-- Car icon circle -->
            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_circle_dark">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:src="@drawable/carrrr"
                    android:scaleType="centerInside"/>
            </FrameLayout>

            <!-- Name + price -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingStart="14dp">

                <TextView
                    android:id="@+id/title"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/priceLabel"
                    android:textColor="#1DB954"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif"
                    android:layout_marginTop="3dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/disponibiliteLabel"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif"
                    android:layout_marginTop="2dp"
                    android:textColor="#80FFFFFF"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Status badge -->
            <TextView
                android:id="@+id/statusBadge"
                android:text="✓ Dispo"
                android:textColor="#1DB954"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:background="@drawable/bg_badge_green"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- DIVIDER -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2A2A2A"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="14dp"/>

        <!-- BOTTOM ROW: details + button -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <!-- Small meta info -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:gravity="center_vertical">

                <TextView
                    android:text="📅"
                    android:textSize="12sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/dateLabel"
                    android:text="Disponible maintenant"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp"
                    android:paddingStart="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- RESERVE BUTTON -->
            <Button
                android:id="@+id/reserveBtn"
                android:text="Réserver"
                android:textColor="#000000"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:background="@drawable/bg_btn_green"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:elevation="0dp"
                android:stateListAnimator="@null"/>

        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>