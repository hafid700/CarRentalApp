<?xml version="1.0" encoding="utf-8"?>
<!--
    ╔══════════════════════════════════════════════════╗
    ║   Dashboard Client — Modern Wave UI (CORRIGÉ)   ║
    ║   Design System: Wave Header + Card White        ║
    ║   Couleur primaire: #0066FF                      ║
    ╚══════════════════════════════════════════════════╝

    CORRECTIONS APPLIQUÉES :
    1. Remplacement du headerContainer FrameLayout par un Guideline à 52%
       pour que la contrainte de hauteur soit valide.
    2. ScrollView correctement contraint entre le guideline et le bas de l'écran.
    3. Suppression de app:layout_constraintHeight_percent non supporté directement
       sur un FrameLayout — on utilise désormais une Guideline horizontale.
    4. Ajout de stateListAnimator="@null" sur les cartes LinearLayout cliquables
       pour éviter l'ombre par défaut sur API 21+.
    5. Correction de la contrainte Bottom du headerContainer liée au guideline.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ═══════════════════════════════════════════════
         GUIDELINE à 52% — sépare header et contenu
         ═══════════════════════════════════════════════ -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.30" />

    <!-- ═══════════════════════════════════════════════
         HEADER — Vague bleue (52% hauteur écran)
         Contraint du haut jusqu'au guideline
         ═══════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/headerContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_wave_header"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/guidelineHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="52dp"
            android:gravity="start">

            <!-- Ligne supérieure : Avatar + Icône notification -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Avatar utilisateur -->
                <FrameLayout
                    android:layout_width="46dp"
                    android:layout_height="46dp">

                    <ImageView
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:background="@drawable/bg_icon_circle"
                        android:padding="10dp"
                        android:src="@drawable/admin_icon"
                        android:alpha="0.65"
                        android:contentDescription="Avatar" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="12dp">

                    <TextView
                        android:id="@+id/tvWelcome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bonjour,"
                        android:textSize="13sp"
                        android:textColor="#BB004B"
                        android:letterSpacing="0.04" />

                    <TextView
                        android:id="@+id/tvUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Administrateur"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#BB004B" />
                </LinearLayout>

                <!-- Bouton Déconnexion (icône) -->
                <ImageView
                    android:id="@+id/btnLogout"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_lock_power_off"
                    android:alpha="0.75"
                    android:tint="#BB004B"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Déconnexion" />
            </LinearLayout>

            <!-- Titre principal du Dashboard -->
            <TextView
                android:id="@+id/tvDashboardTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Dashboard"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#0066FF"
                android:letterSpacing="-0.01" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Gestion de votre espace"
                android:textSize="13sp"
                android:textColor="#0066FF" />

        </LinearLayout>
    </FrameLayout>


    <!-- ═══════════════════════════════════════════════
         CARTE BLANCHE — Contenu principal (arrondie en haut)
         Contraint du guideline jusqu'au bas de l'écran
         ═══════════════════════════════════════════════ -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_card_top_rounded"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/guidelineHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="32dp"
            android:paddingBottom="48dp">

            <!-- ───────────────────────────────────────
                 Section title
                 ─────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Menu principal"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:letterSpacing="0.08"
                android:textAllCaps="true" />

            <View
                android:layout_width="32dp"
                android:layout_height="3dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"
                android:background="#0066FF" />

            <!-- ───────────────────────────────────────
                 GRILLE 2×2 — Ligne 1
                 ─────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <!-- Carte : Gérer les voitures -->
                <LinearLayout
                    android:id="@+id/cardVoitures"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="150dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_dashboard_card"
                    android:elevation="2dp"
                    android:stateListAnimator="@null"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:padding="16dp">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_icon_circle">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:src="@drawable/car_icon"
                            android:tint="#0066FF"
                            android:contentDescription="Voitures" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Voitures"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Gérer le parc"
                        android:textSize="11sp"
                        android:textColor="#888888"
                        android:gravity="center" />
                </LinearLayout>

                <!-- Carte : Gérer les clients -->
                <LinearLayout
                    android:id="@+id/cardClients"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="150dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_dashboard_card"
                    android:elevation="2dp"
                    android:stateListAnimator="@null"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:padding="16dp">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_icon_circle">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_myplaces"
                            android:tint="#0066FF"
                            android:contentDescription="Clients" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Clients"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Gérer les comptes"
                        android:textSize="11sp"
                        android:textColor="#888888"
                        android:gravity="center" />
                </LinearLayout>
            </LinearLayout>

            <!-- GRILLE 2×2 — Ligne 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <!-- Carte : Gérer les réservations -->
                <LinearLayout
                    android:id="@+id/cardReservations"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="150dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_dashboard_card"
                    android:elevation="2dp"
                    android:stateListAnimator="@null"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:padding="16dp">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_icon_circle">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_agenda"
                            android:tint="#0066FF"
                            android:contentDescription="Réservations" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Réservations"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Voir les demandes"
                        android:textSize="11sp"
                        android:textColor="#888888"
                        android:gravity="center" />
                </LinearLayout>

                <!-- Carte placeholder (extensible) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="150dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_dashboard_card"
                    android:alpha="0.45"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@android:drawable/ic_input_add"
                        android:tint="#BBBBBB"
                        android:contentDescription="Ajouter" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Bientôt"
                        android:textSize="13sp"
                        android:textColor="#BBBBBB"
                        android:gravity="center" />
                </LinearLayout>
            </LinearLayout>

            <!-- ───────────────────────────────────────
                 Séparateur
                 ─────────────────────────────────────── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="28dp"
                android:background="#E5E5E5" />

            <!-- ───────────────────────────────────────
                 Bouton Déconnexion (pill, outline)
                 ─────────────────────────────────────── -->
            <Button
                android:id="@+id/btnLogoutBottom"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Se déconnecter"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:background="@drawable/bg_button_outline"
                android:elevation="0dp"
                android:stateListAnimator="@null"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>